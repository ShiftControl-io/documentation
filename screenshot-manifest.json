{
  "$schema": "Screenshot manifest for ShiftControl documentation. Used by AI agents to recapture screenshots.",
  "baseUrl": "https://demo.shiftcontrol.io",
  "localUrl": "http://localhost:8005",
  "viewport": { "width": 1440, "height": 900 },
  "format": "webp",
  "quality": 90,
  "pathPattern": "{section}/{mode_folder}/{theme_folder}/{name}.webp",
  "fallback": "If a mode doesn't have a screenshot, fall back to jc-google. The ModeScreenshot component handles this automatically.",
  "localStartCommand": "cd ~/WebstormProjects/shiftcontrol-saas/services/frontend && npm run dev:test-demo-screenshot",
  "notes": [
    "IMPORTANT: Run dev:test-demo-screenshot (not dev:test-demo) to hide TanStack devtools logo.",
    "Every product screenshot varies by mode — even subtle differences like dropdown arrows on Add buttons in dual-directory modes.",
    "All screenshots are captured per mode × per theme (light + dark).",
    "The 'modes' array on each screenshot controls which mode variants to capture.",
    "Use the localUrl during development, baseUrl for production recaptures.",
    "NAVIGATION: Use direct URLs, NOT clicking. AG Grid rows don't have standard <tr> elements — click navigation fails silently.",
    "MODAL SUPPRESSION: The mode= param triggers a welcome modal. Suppress it BEFORE navigation with: page.addInitScript(() => localStorage.setItem('SC_DEMO_WELCOME_LAST_SHOWN', new Date().toISOString()))",
    "TABS (Users): Use ?tab=security|appPermissions|saasCost URL param. Set mode/theme first, suppress modal, THEN navigate to tab URL.",
    "TABS (Groups/Apps): No URL param support yet — must click Radix UI tabs after page load. Use position-based clicking or [role='tab'] selectors.",
    "SIDEBAR TABS: Right sidebar tabs require clicking after page load. Use position-based x>900 disambiguation.",
    "VERIFICATION: After each capture batch, run duplicate detection to catch navigation failures immediately."
  ],
  "knownIds": {
    "_comment": "Direct-navigable IDs from mock data. Use these in URLs instead of clicking AG Grid rows.",
    "user": "66b42ef6693525dd6b48d7ed",
    "user_first_in_list": "66b417c8b170fe888e997f27",
    "group": "01912fd8-6663-7e31-b98b-9355bcc868be",
