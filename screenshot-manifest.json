    "app_detail_groups": "/admin/org/apps/view/{app_id}?tab=groups",
    "app_detail_individual": "/admin/org/apps/view/{app_id}?tab=individual",
    "app_detail_sso": "/admin/org/apps/view/{app_id}?tab=sso",
