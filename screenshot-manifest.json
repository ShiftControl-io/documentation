    "jc_gws": { "folder": "jc-google", "params": "?mode=jc_gws", "label": "JumpCloud + Google Workspace" },
    "jc_only": { "folder": "jc-only", "params": "?mode=jc_only", "label": "JumpCloud Only" },
    "gws_only": { "folder": "gws-only", "params": "?mode=gws_only", "label": "Google Workspace Only" }
